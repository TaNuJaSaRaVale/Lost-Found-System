rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // DEVELOPMENT MODE: Let all authenticated users read and write everything.
    // This stops 'Missing Permissions' errors while you are building the app.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Note: We will tighten these rules (make them strict) just before you launch
    // to real students to ensure privacy.
  }
}
